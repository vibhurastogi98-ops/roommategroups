{
  "name": "roommategroups",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:web": "cd web && vite",
    "dev:backend": "cd backend && node --env-file=../.env server.js",
    "dev:full": "concurrently \"npm run dev:web\" \"npm run dev:backend\"",
    "build:web": "cd web && vite build",
    "build:android": "npm run build:web && cd mobile && npx cap sync android && npx cap open android",
    "build:ios": "npm run build:web && cd mobile && npx cap sync ios && npx cap open ios",
    "deploy": "npm run build:web && cd backend && wrangler deploy",
    "dev": "npm run dev:web",
    "build": "npm run build:web",
    "server": "npm run dev:backend"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.1",
    "@cloudflare/workers-types": "^4.20260422.1",
    "concurrently": "^9.2.1",
    "vite": "^7.3.1",
    "vite-plugin-sitemap": "^0.8.2",
    "wrangler": "^4.84.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/keyboard": "^8.0.3",
    "@google/generative-ai": "^0.24.1",
    "@vitejs/plugin-react": "^5.1.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "hono": "^4.12.14",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
